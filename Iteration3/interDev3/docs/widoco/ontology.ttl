@prefix : <https://erct.adaptcentre.com/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://erct.adaptcentre.com/ontology#> .

<https://erct.adaptcentre.com/ontology> rdf:type owl:Ontology ;
                                         owl:versionIRI <https://erct.adaptcentre.com/ontology/5.0.0> ;
                                         owl:imports <http://www.w3.org/2004/02/skos/core> ,
                                                     <http://www.w3.org/ns/prov-o> ;
                                         <http://purl.org/dc/terms/bibliographicCitation> "Evidence from Randomised Controlled Trials Ontology (ERCT), version 5.0.0."@en ;
                                         <http://purl.org/dc/terms/created> "2026-02-07"^^xsd:date ;
                                         <http://purl.org/dc/terms/creator> "ERCT project team"@en ;
                                         <http://purl.org/dc/terms/identifier> <https://doi.org/10.5281/zenodo.10993684> ;
                                         <http://purl.org/dc/terms/issued> "2026-02-07"^^xsd:date ;
                                         <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                         <http://purl.org/dc/terms/publisher> "ERCT project"@en ;
                                         <http://purl.org/dc/terms/source> "ERCT ontology source distribution"@en ;
                                         <http://purl.org/dc/terms/title> "Evidence from Randomised Controlled Trials Ontology"@en ;
                                         <http://purl.org/ontology/bibo/doi> "10.5281/zenodo.10993684" ;
                                         <http://purl.org/vocab/vann/preferredNamespacePrefix> "erct" ;
                                         <http://purl.org/vocab/vann/preferredNamespaceUri> "https://erct.adaptcentre.com/ontology#" ;
                                         rdfs:comment "Adds Finding-level evidence units and strengthens SKOS lexical coverage for robust search and filtering; does not model interaction logs or user trust measures."@en ,
                                                      "ERCT models randomised controlled trial evidence for search, filtering, submission, and export workflows."@en ;
                                         rdfs:label "Evidence from Randomised Controlled Trials Ontology"@en ;
                                         owl:versionInfo "5.0.0" ;
                                         <http://xmlns.com/foaf/0.1/logo> <https://zenodo.org/badge/DOI/10.5281/zenodo.10993684.svg> ;
                                         <https://w3id.org/mod#status> "active" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/bibliographicCitation
<http://purl.org/dc/terms/bibliographicCitation> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/identifier
<http://purl.org/dc/terms/identifier> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
<http://purl.org/dc/terms/issued> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/publisher
<http://purl.org/dc/terms/publisher> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/source
<http://purl.org/dc/terms/source> rdf:type owl:AnnotationProperty .


###  http://purl.org/ontology/bibo/doi
<http://purl.org/ontology/bibo/doi> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/logo
<http://xmlns.com/foaf/0.1/logo> rdf:type owl:AnnotationProperty .


###  https://erct.adaptcentre.com/ontology#legacyLiteralValue
:legacyLiteralValue rdf:type owl:AnnotationProperty ;
                    rdfs:comment "Legacy literal encoding for a controlled concept. Use this as an alignment hook when migrating literal facet values to concept IRIs."@en ;
                    rdfs:label "legacy literal value"@en ;
                    rdfs:range xsd:string ;
                    rdfs:domain <http://www.w3.org/2004/02/skos/core#Concept> .


###  https://erct.adaptcentre.com/ontology#uiExample
:uiExample rdf:type owl:AnnotationProperty ;
           rdfs:comment "Optional UI hint showing a representative example value."@en ;
           rdfs:label "UI example"@en .


###  https://erct.adaptcentre.com/ontology#uiPlaceholder
:uiPlaceholder rdf:type owl:AnnotationProperty ;
               rdfs:comment "Optional UI hint for placeholder text shown in a form field."@en ;
               rdfs:label "UI placeholder"@en .


###  https://erct.adaptcentre.com/ontology#uiSection
:uiSection rdf:type owl:AnnotationProperty ;
           rdfs:comment "Optional UI hint indicating where a field appears in forms or filter panels."@en ;
           rdfs:label "UI section"@en .


###  https://w3id.org/mod#status
<https://w3id.org/mod#status> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://erct.adaptcentre.com/ontology#aboutIntervention
:aboutIntervention rdf:type owl:ObjectProperty ;
                   rdfs:domain :Finding ;
                   rdfs:range :Intervention ;
                   rdfs:comment "Links a finding to the intervention context that the reported result is about."@en ;
                   rdfs:label "about intervention"@en .


###  https://erct.adaptcentre.com/ontology#attributedTo
:attributedTo rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasAttributedTo> ;
              rdfs:domain :EntityWithProvenance ;
              rdfs:range :Agent ;
              rdfs:comment "Links an evidence entity to the responsible agent."@en ;
              rdfs:label "attributed to"@en .


###  https://erct.adaptcentre.com/ontology#clusteredBy
:clusteredBy rdf:type owl:ObjectProperty ;
             rdfs:domain :Clustered ;
             rdfs:range :ClusterUnitType ;
             rdfs:comment "Specifies cluster unit type for clustered sampling, for example village, school, or district."@en ;
             rdfs:label "clustered by"@en .


###  https://erct.adaptcentre.com/ontology#conductedBy
:conductedBy rdf:type owl:ObjectProperty ;
             rdfs:domain :Trial ;
             rdfs:range :Researcher ;
             rdfs:comment "Links a trial to the researcher who conducted it."@en ;
             rdfs:label "conducted by"@en .


###  https://erct.adaptcentre.com/ontology#extractedFromDocument
:extractedFromDocument rdf:type owl:ObjectProperty ;
                       rdfs:domain :ExtractionRun ;
                       rdfs:range :SourceDocument ;
                       rdfs:comment "Identifies the source document used for automated extraction."@en ;
                       rdfs:label "extracted from document"@en ;
                       :uiExample "http://example.org/document/impact-eval-2024-pdf" ;
                       :uiPlaceholder "Link to source document IRI" ;
                       :uiSection "Extraction provenance" .


###  https://erct.adaptcentre.com/ontology#generatedAtTime
:generatedAtTime rdf:type owl:ObjectProperty ;
                 rdfs:domain :EntityWithProvenance ;
                 rdfs:range :Timespan ;
                 rdfs:comment "Deprecated legacy object property linking to erct:Timespan. Use prov:generatedAtTime with an xsd:dateTime literal for canonical provenance timestamps."@en ;
                 rdfs:label "generated at time (deprecated)"@en ;
                 owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#generatedBy
:generatedBy rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasGeneratedBy> ;
             rdfs:domain :EntityWithProvenance ;
             rdfs:range :ProvenanceActivity ;
             rdfs:comment "Links an evidence entity to the activity that generated it."@en ;
             rdfs:label "generated by"@en .


###  https://erct.adaptcentre.com/ontology#hasCountry
:hasCountry rdf:type owl:ObjectProperty ;
            rdfs:domain :Trial ;
            rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
            rdfs:comment "Facet property used by the UI to filter trials by country. Canonical values are controlled IRIs of skos:Concept in erct:CountryScheme, ideally aligned to ISO country identifiers. Legacy data may contain literal values. Pipelines should migrate or align literals to controlled concept IRIs via skos:altLabel or erct:legacyLiteralValue."@en ;
            rdfs:label "has country"@en ;
            :uiExample "http://example.org/country/KE" ;
            :uiPlaceholder "Select one or more countries" ;
            :uiSection "Filters" .


###  https://erct.adaptcentre.com/ontology#hasEvaluationMethod
:hasEvaluationMethod rdf:type owl:ObjectProperty ;
                     rdfs:domain :Trial ;
                     rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                     rdfs:comment "Facet property for evaluation design or methodology. Canonical values are controlled IRIs of skos:Concept in erct:EvaluationMethodScheme, for example individual randomization or stratified randomization. Legacy data may contain literal values. Pipelines should migrate or align literals to controlled concept IRIs via skos:altLabel or erct:legacyLiteralValue."@en ;
                     rdfs:label "has evaluation method"@en ;
                     :uiExample "http://example.org/method/stratified_randomization" ;
                     :uiPlaceholder "Select evaluation method" ;
                     :uiSection "Filters" .


###  https://erct.adaptcentre.com/ontology#hasEvidenceCompleteness
:hasEvidenceCompleteness rdf:type owl:ObjectProperty ;
                         rdfs:domain :Finding ;
                         rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                         rdfs:comment "Links a finding to a controlled completeness status. Values should be skos:Concept in erct:EvidenceCompletenessScheme."@en ;
                         rdfs:label "has evidence completeness"@en .


###  https://erct.adaptcentre.com/ontology#hasEvidenceType
:hasEvidenceType rdf:type owl:ObjectProperty ;
                 rdfs:domain :Finding ;
                 rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                 rdfs:comment "Links a finding to the type of supporting evidence source. Values should be skos:Concept in erct:EvidenceTypeScheme."@en ;
                 rdfs:label "has evidence type"@en .


###  https://erct.adaptcentre.com/ontology#hasExperimentalDesignType
:hasExperimentalDesignType rdf:type owl:ObjectProperty ;
                           rdfs:domain :Methodology ;
                           rdfs:range :EvaluationMethod ;
                           rdfs:comment "Deprecated ambiguous facet-like property. Use erct:hasEvaluationMethod for filtering and erct:hasMethodology for structured methodology nodes."@en ;
                           rdfs:label "has experimental design type (deprecated)"@en ;
                           owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#hasExternalClassification
:hasExternalClassification rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf owl:topObjectProperty ;
                           rdfs:domain :Trial ;
                           rdfs:range :ExternalClassification ;
                           rdfs:label "hasExternalClassification"@en .


###  https://erct.adaptcentre.com/ontology#hasExtractionRun
:hasExtractionRun rdf:type owl:ObjectProperty ;
                  rdfs:domain :Submission ;
                  rdfs:range :ExtractionRun ;
                  rdfs:comment "Links a submission to the extraction run used to pre-populate metadata."@en ;
                  rdfs:label "has extraction run"@en ;
                  :uiExample "http://example.org/extraction/run-2026-02-07-01" ;
                  :uiPlaceholder "Link to extraction run IRI" ;
                  :uiSection "Extraction provenance" .


###  https://erct.adaptcentre.com/ontology#hasFinding
:hasFinding rdf:type owl:ObjectProperty ;
            rdfs:domain :Trial ;
            rdfs:range :Finding ;
            rdfs:comment "Links a trial to a finding-level unit of reported evidence used for citation and comparison."@en ;
            rdfs:label "has finding"@en .


###  https://erct.adaptcentre.com/ontology#hasFindingOutcomeDomain
:hasFindingOutcomeDomain rdf:type owl:ObjectProperty ;
                         rdfs:domain :Finding ;
                         rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                         rdfs:comment "Links a finding to an outcome-domain concept. Values should be skos:Concept in erct:OutcomeDomainScheme. Legacy literal values may exist and require alignment during ingestion."@en ;
                         rdfs:label "has finding outcome domain"@en .


###  https://erct.adaptcentre.com/ontology#hasFindingProvenanceInfo
:hasFindingProvenanceInfo rdf:type owl:ObjectProperty ;
                          rdfs:domain :Finding ;
                          rdfs:range :EntityWithProvenance ;
                          rdfs:comment "Links a finding to provenance metadata entities using the same provenance model applied at trial level."@en ;
                          rdfs:label "has finding provenance information"@en .


###  https://erct.adaptcentre.com/ontology#hasIndicator
:hasIndicator rdf:type owl:ObjectProperty ;
              rdfs:domain :Country ;
              rdfs:range :Indicator ;
              rdfs:comment "Links a country to one or more contextual indicators used in evidence exploration and exports."@en ;
              rdfs:label "has indicator"@en .


###  https://erct.adaptcentre.com/ontology#hasIntervention
:hasIntervention rdf:type owl:ObjectProperty ;
                 rdfs:range :Intervention ;
                 rdfs:comment "Links a trial or treatment arm to an intervention instance."@en ;
                 rdfs:label "has intervention"@en .


###  https://erct.adaptcentre.com/ontology#hasInterventionType
:hasInterventionType rdf:type owl:ObjectProperty ;
                     rdfs:domain :Trial ;
                     rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                     rdfs:comment "Facet property for intervention category. Canonical values are controlled IRIs of skos:Concept in erct:InterventionTypeScheme. Legacy data may contain literal values. Pipelines should migrate or align literals to controlled concept IRIs via skos:altLabel or erct:legacyLiteralValue."@en ;
                     rdfs:label "has intervention type"@en ;
                     :uiExample "http://example.org/intervention/conditional_cash_transfer" ;
                     :uiPlaceholder "Select intervention type" ;
                     :uiSection "Filters" .


###  https://erct.adaptcentre.com/ontology#hasMethod
:hasMethod rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :hasMethodology ;
           rdfs:domain :Trial ;
           rdfs:range :Methodology ;
           rdfs:comment "Legacy property from earlier mapped datasets. Use erct:hasMethodology."@en ;
           rdfs:label "hasMethod (deprecated)"@en ;
           owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#hasMethodology
:hasMethodology rdf:type owl:ObjectProperty ;
                rdfs:domain :Trial ;
                rdfs:range :Methodology ;
                rdfs:comment "Links a trial to detailed methodology metadata nodes."@en ;
                rdfs:label "has methodology"@en .


###  https://erct.adaptcentre.com/ontology#hasOutcomeDomain
:hasOutcomeDomain rdf:type owl:ObjectProperty ;
                  rdfs:domain :Trial ;
                  rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                  rdfs:comment "Facet property for broad outcome domain. Canonical values are controlled IRIs of skos:Concept in erct:OutcomeDomainScheme, such as health or income. Legacy data may contain literal values. Pipelines should migrate or align literals to controlled concept IRIs via skos:altLabel or erct:legacyLiteralValue."@en ;
                  rdfs:label "has outcome domain"@en ;
                  :uiExample "http://example.org/outcome/income" ;
                  :uiPlaceholder "Select outcome domain" ;
                  :uiSection "Filters" .


###  https://erct.adaptcentre.com/ontology#hasProvenanceInfo
:hasProvenanceInfo rdf:type owl:ObjectProperty ;
                   rdfs:domain :Trial ;
                   rdfs:range :EntityWithProvenance ;
                   rdfs:comment "Links a trial to provenance metadata entities."@en ;
                   rdfs:label "has provenance information"@en .


###  https://erct.adaptcentre.com/ontology#hasProvenenceInfo
:hasProvenenceInfo rdf:type owl:ObjectProperty ;
                   rdfs:comment "Deprecated misspelling. Use erct:hasProvenanceInfo."@en ;
                   rdfs:label "has provenence information (deprecated typo)"@en ;
                   owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#hasPublicationInfo
:hasPublicationInfo rdf:type owl:ObjectProperty ;
                    rdfs:domain :Trial ;
                    rdfs:range :publicationInfo ;
                    rdfs:comment "Links a trial to bibliographic metadata such as DOI and JEL codes."@en ;
                    rdfs:label "has publication information"@en .


###  https://erct.adaptcentre.com/ontology#hasSampling
:hasSampling rdf:type owl:ObjectProperty ;
             rdfs:range :Sampling ;
             rdfs:comment "Links a trial or methodology node to sampling metadata."@en ;
             rdfs:label "has sampling"@en .


###  https://erct.adaptcentre.com/ontology#hasSector
:hasSector rdf:type owl:ObjectProperty ;
           rdfs:domain :Trial ;
           rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
           rdfs:comment "Facet property used by the UI to filter trials by sector. Canonical values are controlled IRIs of skos:Concept in erct:SectorScheme. Legacy data may contain literal values. Pipelines should migrate or align literals to controlled concept IRIs via skos:altLabel or erct:legacyLiteralValue."@en ;
           rdfs:label "has sector"@en ;
           :uiExample "http://example.org/sector/health" ;
           :uiPlaceholder "Select one or more sectors" ;
           :uiSection "Filters" .


###  https://erct.adaptcentre.com/ontology#hasSubmission
:hasSubmission rdf:type owl:ObjectProperty ;
               rdfs:domain :Trial ;
               rdfs:range :Submission ;
               rdfs:comment "Links a trial record to the submission event that created or updated it."@en ;
               rdfs:label "has submission"@en ;
               :uiExample "http://example.org/submission/aea-1230-2026-02-07" ;
               :uiPlaceholder "Link to submission event IRI" ;
               :uiSection "Submission provenance" .


###  https://erct.adaptcentre.com/ontology#hasTimespan
:hasTimespan rdf:type owl:ObjectProperty ;
             rdfs:range :Timespan ;
             rdfs:comment "Links a trial, intervention, or treatment arm to a start and end date container."@en ;
             rdfs:label "has timespan"@en .


###  https://erct.adaptcentre.com/ontology#hasTreatmentArm
:hasTreatmentArm rdf:type owl:ObjectProperty ;
                 rdfs:domain :Trial ;
                 rdfs:range :TreatmentArm ;
                 rdfs:comment "Links a trial to one or more treatment arms."@en ;
                 rdfs:label "has treatment arm"@en .


###  https://erct.adaptcentre.com/ontology#hasTreatmentVar
:hasTreatmentVar rdf:type owl:ObjectProperty ;
                 rdfs:domain :TreatmentArm ;
                 rdfs:range :TreatmentVar ;
                 rdfs:comment "Links a treatment arm to treatment-effect metadata."@en ;
                 rdfs:label "has treatment variable"@en .


###  https://erct.adaptcentre.com/ontology#hasTreatmentVariable
:hasTreatmentVariable rdf:type owl:ObjectProperty ;
                      rdfs:domain :Finding ;
                      rdfs:range :TreatmentVar ;
                      rdfs:comment "Links a finding to the treatment-variable node containing effect-size and p-value details."@en ;
                      rdfs:label "has treatment variable"@en .


###  https://erct.adaptcentre.com/ontology#hasublicationInfo
:hasublicationInfo rdf:type owl:ObjectProperty ;
                   rdfs:comment "Deprecated typo from earlier mappings. Use erct:hasPublicationInfo."@en ;
                   rdfs:label "has publication information (deprecated typo)"@en ;
                   owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#ingestionMethod
:ingestionMethod rdf:type owl:ObjectProperty ;
                 rdfs:domain :Submission ;
                 rdfs:range :IngestionMethod ;
                 rdfs:comment "Controlled method describing how the submission metadata was ingested. Use concepts such as erct:ManualIngestion or erct:LLMAssistedIngestion."@en ;
                 rdfs:label "ingestion method"@en ;
                 :uiExample "erct:LLMAssistedIngestion" ;
                 :uiPlaceholder "manual or llm-assisted" ;
                 :uiSection "Submission provenance" .


###  https://erct.adaptcentre.com/ontology#locatedIn
:locatedIn rdf:type owl:ObjectProperty ;
           rdfs:domain :Region ;
           rdfs:range :Country ;
           rdfs:comment "Links a sub-national place such as a region to its parent country."@en ;
           rdfs:label "located in"@en .


###  https://erct.adaptcentre.com/ontology#performedBy
:performedBy rdf:type owl:ObjectProperty ;
             rdfs:range :Agent ;
             rdfs:comment "General relation linking an activity-like entity to the responsible agent."@en ;
             rdfs:label "performed by"@en .


###  https://erct.adaptcentre.com/ontology#reviewedBy
:reviewedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :Submission ;
            rdfs:range :Agent ;
            rdfs:comment "Identifies the reviewer who confirmed or edited extracted metadata before acceptance."@en ;
            rdfs:label "reviewed by"@en ;
            :uiExample "http://example.org/agent/reviewer-17" ;
            :uiPlaceholder "Reviewer identifier" ;
            :uiSection "Submission provenance" .


###  https://erct.adaptcentre.com/ontology#statifiedBy
:statifiedBy rdf:type owl:ObjectProperty ;
             rdfs:comment "Deprecated misspelling. Use erct:stratifiedBy."@en ;
             rdfs:label "statified by (deprecated typo)"@en ;
             owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#stratifiedBy
:stratifiedBy rdf:type owl:ObjectProperty ;
              rdfs:domain :Stratified ;
              rdfs:range :demographicVariable ;
              rdfs:comment "Specifies the demographic variable used in stratified randomisation, for example gender or county."@en ;
              rdfs:label "stratified by"@en .


###  https://erct.adaptcentre.com/ontology#takesPlaceIn
:takesPlaceIn rdf:type owl:ObjectProperty ;
              rdfs:range :Place ;
              rdfs:comment "Links an intervention or treatment arm to a place where it occurs."@en ;
              rdfs:label "takes place in"@en .


###  https://erct.adaptcentre.com/ontology#tookPlaceIn
:tookPlaceIn rdf:type owl:ObjectProperty ;
             rdfs:comment "Deprecated legacy spelling. Use erct:takesPlaceIn for event location and erct:hasCountry for trial filtering."@en ;
             rdfs:label "took place in (deprecated)"@en ;
             owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#used
:used rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf <http://www.w3.org/ns/prov#used> ;
      rdfs:domain :ProvenanceActivity ;
      rdfs:range :EntityWithProvenance ;
      rdfs:comment "Indicates that a provenance activity used a prior evidence entity as input."@en ;
      rdfs:label "used"@en .


###  https://erct.adaptcentre.com/ontology#wasInformedBy
:wasInformedBy rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasInformedBy> ;
               rdfs:domain :ProvenanceActivity ;
               rdfs:range :ProvenanceActivity ;
               rdfs:comment "Relates a provenance activity to another provenance activity that informed it."@en ;
               rdfs:label "was informed by"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.w3.org/ns/prov#generatedAtTime
<http://www.w3.org/ns/prov#generatedAtTime> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain :EntityWithProvenance ;
                                            rdfs:range xsd:dateTime ;
                                            rdfs:comment "Canonical provenance timestamp for when an evidence entity was generated. Use xsd:dateTime literals, for example 2026-02-09T10:30:00Z."@en ;
                                            rdfs:label "generated at time"@en .


###  https://erct.adaptcentre.com/ontology#Abstract
:Abstract rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf owl:topDataProperty ;
          rdfs:label "Abstract"@en .


###  https://erct.adaptcentre.com/ontology#Additional_Dataset_Information
:Additional_Dataset_Information rdf:type owl:DatatypeProperty ;
                                rdfs:subPropertyOf owl:topDataProperty ;
                                rdfs:label "Additional_Dataset_Information"@en .


###  https://erct.adaptcentre.com/ontology#Analysis_Code_Format
:Analysis_Code_Format rdf:type owl:DatatypeProperty ;
                      rdfs:subPropertyOf owl:topDataProperty ;
                      rdfs:label "Analysis_Code_Format"@en .


###  https://erct.adaptcentre.com/ontology#Authors
:Authors rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf owl:topDataProperty ;
         rdfs:label "Authors"@en .


###  https://erct.adaptcentre.com/ontology#CRS_Voluntary_DAC_Code
:CRS_Voluntary_DAC_Code rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf owl:topDataProperty ;
                        rdfs:label "CRS_Voluntary_DAC_Code"@en .


###  https://erct.adaptcentre.com/ontology#Countries
:Countries rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:label "Countries"@en .


###  https://erct.adaptcentre.com/ontology#Equity_dimension
:Equity_dimension rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf owl:topDataProperty ;
                  rdfs:label "Equity_dimension"@en .


###  https://erct.adaptcentre.com/ontology#Equity_focus
:Equity_focus rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:label "Equity_focus"@en .


###  https://erct.adaptcentre.com/ontology#Ethics_Approval
:Ethics_Approval rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdfs:label "Ethics_Approval"@en .


###  https://erct.adaptcentre.com/ontology#Evaluation_design
:Evaluation_design rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf owl:topDataProperty ;
                   rdfs:label "Evaluation_design"@en .


###  https://erct.adaptcentre.com/ontology#Implementation_agency
:Implementation_agency rdf:type owl:DatatypeProperty ;
                       rdfs:subPropertyOf owl:topDataProperty ;
                       rdfs:label "Implementation_agency"@en .


###  https://erct.adaptcentre.com/ontology#Keywords
:Keywords rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf owl:topDataProperty ;
          rdfs:label "Keywords"@en .


###  https://erct.adaptcentre.com/ontology#Language
:Language rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf owl:topDataProperty ;
          rdfs:label "Language"@en .


###  https://erct.adaptcentre.com/ontology#Mixed_method
:Mixed_method rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:label "Mixed_method"@en .


###  https://erct.adaptcentre.com/ontology#Open_Access
:Open_Access rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:label "Open_Access"@en .


###  https://erct.adaptcentre.com/ontology#Pre-Registration
:Pre-Registration rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf owl:topDataProperty ;
                  rdfs:label "Pre-Registration"@en .


###  https://erct.adaptcentre.com/ontology#Primary_Dataset_Availability
:Primary_Dataset_Availability rdf:type owl:DatatypeProperty ;
                              rdfs:subPropertyOf owl:topDataProperty ;
                              rdfs:label "Primary_Dataset_Availability"@en .


###  https://erct.adaptcentre.com/ontology#Primary_Dataset_Format
:Primary_Dataset_Format rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf owl:topDataProperty ;
                        rdfs:label "Primary_Dataset_Format"@en .


###  https://erct.adaptcentre.com/ontology#Program_funding_agency
:Program_funding_agency rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf owl:topDataProperty ;
                        rdfs:label "Program_funding_agency"@en .


###  https://erct.adaptcentre.com/ontology#Project_name
:Project_name rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:label "Project_name"@en .


###  https://erct.adaptcentre.com/ontology#Protocol_Pre-Analysis_Plan
:Protocol_Pre-Analysis_Plan rdf:type owl:DatatypeProperty ;
                            rdfs:subPropertyOf owl:topDataProperty ;
                            rdfs:label "Protocol_Pre-Analysis_Plan"@en .


###  https://erct.adaptcentre.com/ontology#Research_funding_agency
:Research_funding_agency rdf:type owl:DatatypeProperty ;
                         rdfs:subPropertyOf owl:topDataProperty ;
                         rdfs:label "Research_funding_agency"@en .


###  https://erct.adaptcentre.com/ontology#Secondary_Dataset_Name
:Secondary_Dataset_Name rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf owl:topDataProperty ;
                        rdfs:label "Secondary_Dataset_Name"@en .


###  https://erct.adaptcentre.com/ontology#Sub-sector
:Sub-sector rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:label "Sub-sector"@en .


###  https://erct.adaptcentre.com/ontology#Unit_of_observation
:Unit_of_observation rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf owl:topDataProperty ;
                     rdfs:label "Unit_of_observation"@en .


###  https://erct.adaptcentre.com/ontology#extractionTimestamp
:extractionTimestamp rdf:type owl:DatatypeProperty ;
                     rdfs:domain :ExtractionRun ;
                     rdfs:range xsd:dateTime ;
                     rdfs:comment "Date-time when the extraction run generated candidate metadata."@en ;
                     rdfs:label "extraction timestamp"@en ;
                     :uiExample "2026-02-07T15:20:00Z" ;
                     :uiPlaceholder "2026-02-07T15:20:00Z" ;
                     :uiSection "Extraction provenance" .


###  https://erct.adaptcentre.com/ontology#hasAbstract
:hasAbstract rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:label "hasAbstract"@en .


###  https://erct.adaptcentre.com/ontology#hasAffiliation
:hasAffiliation rdf:type owl:DatatypeProperty ;
                rdfs:domain :Researcher ;
                rdfs:range xsd:string ;
                rdfs:comment "Institutional affiliation for a researcher."@en ;
                rdfs:label "has affiliation"@en .


###  https://erct.adaptcentre.com/ontology#hasConfidenceIntervalLower
:hasConfidenceIntervalLower rdf:type owl:DatatypeProperty ;
                            rdfs:domain :Finding ;
                            rdfs:range xsd:decimal ;
                            rdfs:comment "Lower bound of the confidence interval for a finding effect estimate."@en ;
                            rdfs:label "has confidence interval lower"@en .


###  https://erct.adaptcentre.com/ontology#hasConfidenceIntervalUpper
:hasConfidenceIntervalUpper rdf:type owl:DatatypeProperty ;
                            rdfs:domain :Finding ;
                            rdfs:range xsd:decimal ;
                            rdfs:comment "Upper bound of the confidence interval for a finding effect estimate."@en ;
                            rdfs:label "has confidence interval upper"@en .


###  https://erct.adaptcentre.com/ontology#hasControlGroupSize
:hasControlGroupSize rdf:type owl:DatatypeProperty ;
                     rdfs:domain :TreatmentArm ;
                     rdfs:range xsd:integer ;
                     rdfs:comment "Number of observations in the control arm."@en ;
                     rdfs:label "has control group size"@en .


###  https://erct.adaptcentre.com/ontology#hasDAC
:hasDAC rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf owl:topDataProperty ;
        rdfs:label "hasDAC"@en .


###  https://erct.adaptcentre.com/ontology#hasDOI
:hasDOI rdf:type owl:DatatypeProperty ;
        rdfs:domain :publicationInfo ;
        rdfs:range xsd:string ;
        rdfs:comment "DOI identifier for a publication. Use canonical DOI format such as 10.1257/rct.1505-3.0."@en ;
        rdfs:label "has DOI"@en ;
        :uiExample "10.1257/rct.1505-3.0" ;
        :uiPlaceholder "10.xxxx/xxxx" ;
        :uiSection "Submission" .


###  https://erct.adaptcentre.com/ontology#hasEffectEstimate
:hasEffectEstimate rdf:type owl:DatatypeProperty ;
                   rdfs:domain :Finding ;
                   rdfs:range xsd:decimal ;
                   rdfs:comment "Primary effect estimate at finding level for export and cross-trial synthesis. When a linked treatment variable exists, values should be aligned."@en ;
                   rdfs:label "has effect estimate"@en .


###  https://erct.adaptcentre.com/ontology#hasEmail
:hasEmail rdf:type owl:DatatypeProperty ;
          rdfs:domain :Researcher ;
          rdfs:range xsd:string ;
          rdfs:comment "Email address for a researcher contact. Valid input should be a single email address; avoid adding names, labels, or multiple addresses in one value."@en ;
          rdfs:label "has email"@en ;
          :uiExample "j.doe@university.edu" ;
          :uiPlaceholder "name@example.org" ;
          :uiSection "Submission" .


###  https://erct.adaptcentre.com/ontology#hasEndDate
:hasEndDate rdf:type owl:DatatypeProperty ;
            rdfs:domain :Timespan ;
            rdfs:range xsd:date ;
            rdfs:comment "End date for trial implementation. Use ISO date format YYYY-MM-DD when possible."@en ;
            rdfs:label "has end date"@en ;
            :uiExample "2022-12-31" ;
            :uiPlaceholder "2023-06-30" ;
            :uiSection "Submission" .


###  https://erct.adaptcentre.com/ontology#hasISO
:hasISO rdf:type owl:DatatypeProperty ;
        rdfs:domain :Region ;
        rdfs:range xsd:string ;
        rdfs:comment "Generic ISO-like code for region records in exports, for example subdivision codes."@en ;
        rdfs:label "has ISO code"@en ;
        :uiExample "ZM-02" ;
        :uiSection "Exports" .


###  https://erct.adaptcentre.com/ontology#hasISOAlpha2
:hasISOAlpha2 rdf:type owl:DatatypeProperty ;
              rdfs:domain :Country ;
              rdfs:range xsd:string ;
              rdfs:comment "Two-letter ISO 3166-1 country code used in exports and tabular joins."@en ;
              rdfs:label "has ISO alpha-2 code"@en ;
              :uiExample "KE" ;
              :uiSection "Exports" .


###  https://erct.adaptcentre.com/ontology#hasISOAlpha3
:hasISOAlpha3 rdf:type owl:DatatypeProperty ;
              rdfs:domain :Country ;
              rdfs:range xsd:string ;
              rdfs:comment "Three-letter ISO 3166-1 country code used in external data integration."@en ;
              rdfs:label "has ISO alpha-3 code"@en ;
              :uiExample "KEN" ;
              :uiSection "Exports" .


###  https://erct.adaptcentre.com/ontology#hasIndicatorType
:hasIndicatorType rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Indicator ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Human-readable type of indicator, for example HDI, GDP, or net savings."@en ;
                  rdfs:label "has indicator type"@en ;
                  :uiSection "Evidence view" .


###  https://erct.adaptcentre.com/ontology#hasJELcode
:hasJELcode rdf:type owl:DatatypeProperty ;
            rdfs:domain :publicationInfo ;
            rdfs:range xsd:string ;
            rdfs:comment "JEL code list for trial publications. Use standard JEL codes such as I25 or O12, separated consistently in data-entry workflows."@en ;
            rdfs:label "has JEL code"@en ;
            :uiExample "H43" ;
            :uiPlaceholder "I25, O12" ;
            :uiSection "Submission" .


###  https://erct.adaptcentre.com/ontology#hasMDE
:hasMDE rdf:type owl:DatatypeProperty ;
        rdfs:domain :Methodology ;
        rdfs:range xsd:decimal ;
        rdfs:comment "Minimum detectable effect value reported in methodology metadata. Valid input is numeric."@en ;
        rdfs:label "has minimum detectable effect"@en ;
        :uiExample "0.15" ;
        :uiPlaceholder "0.2" ;
        :uiSection "Submission" .


###  https://erct.adaptcentre.com/ontology#hasName
:hasName rdf:type owl:DatatypeProperty ;
         rdfs:range xsd:string ;
         rdfs:comment "Human-readable display name for an entity."@en ;
         rdfs:label "has name"@en .


###  https://erct.adaptcentre.com/ontology#hasNoOfClusters
:hasNoOfClusters rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Clustered ;
                 rdfs:range xsd:integer ;
                 rdfs:comment "Number of clusters used in clustered randomisation. Valid input is a numeric count only; do not include unit words in the same field."@en ;
                 rdfs:label "has number of clusters"@en ;
                 :uiExample "120" ;
                 :uiPlaceholder "64" ;
                 :uiSection "Submission" .


###  https://erct.adaptcentre.com/ontology#hasOutcome
:hasOutcome rdf:type owl:DatatypeProperty ;
            rdfs:domain :Intervention ;
            rdfs:range xsd:string ;
            rdfs:comment "Free-text outcome description captured from source records. Use erct:hasOutcomeDomain for filterable controlled categorisation."@en ;
            rdfs:label "has outcome text"@en ;
            :uiExample "Voter turnout" ;
            :uiPlaceholder "Primary school enrollment rate" ;
            :uiSection "Submission" .


###  https://erct.adaptcentre.com/ontology#hasPValue
:hasPValue rdf:type owl:DatatypeProperty ;
           rdfs:domain :TreatmentVar ;
           rdfs:range xsd:decimal ;
           rdfs:comment "P-value associated with a treatment estimate. Valid input is a decimal number between 0 and 1."@en ;
           rdfs:label "has p-value"@en ;
           :uiExample "0.012" ;
           :uiPlaceholder "0.05" ;
           :uiSection "Submission" .


###  https://erct.adaptcentre.com/ontology#hasPower
:hasPower rdf:type owl:DatatypeProperty ;
          rdfs:domain :Methodology ;
          rdfs:range xsd:decimal ;
          rdfs:comment "Statistical power used in study design. Use a decimal probability between 0 and 1 when available."@en ;
          rdfs:label "has power"@en .


###  https://erct.adaptcentre.com/ontology#hasPublicationDate
:hasPublicationDate rdf:type owl:DatatypeProperty ;
                    rdfs:domain :publicationInfo ;
                    rdfs:range xsd:date ;
                    rdfs:comment "Publication date for trial outputs. Use ISO date format YYYY-MM-DD."@en ;
                    rdfs:label "has publication date"@en ;
                    :uiExample "2023-06-15" ;
                    :uiPlaceholder "2024-10-01" ;
                    :uiSection "Submission" .


###  https://erct.adaptcentre.com/ontology#hasSampleSize
:hasSampleSize rdf:type owl:DatatypeProperty ;
               rdfs:domain :Sampling ;
               rdfs:range xsd:integer ;
               rdfs:comment "Total number of observations used in the analysis. Valid input is an integer count. Avoid free text values such as \"about 200\" or missing-value tokens such as N/A."@en ;
               rdfs:label "has sample size"@en ;
               :uiExample "850" ;
               :uiPlaceholder "1200" ;
               :uiSection "Submission" .


###  https://erct.adaptcentre.com/ontology#hasStartDate
:hasStartDate rdf:type owl:DatatypeProperty ;
              rdfs:domain :Timespan ;
              rdfs:range xsd:date ;
              rdfs:comment "Start date for trial implementation. Use ISO date format YYYY-MM-DD when possible."@en ;
              rdfs:label "has start date"@en ;
              :uiExample "2020-01-15" ;
              :uiPlaceholder "2021-09-01" ;
              :uiSection "Submission" .


###  https://erct.adaptcentre.com/ontology#hasTitle
:hasTitle rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf :hasName ;
          rdfs:domain :publicationInfo ;
          rdfs:range xsd:string ;
          rdfs:comment "Legacy property from earlier mapped datasets. Use erct:hasName."@en ;
          rdfs:label "hasTitle (deprecated)"@en ;
          owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#hasTreatmentEffect
:hasTreatmentEffect rdf:type owl:DatatypeProperty ;
                    rdfs:domain :TreatmentVar ;
                    rdfs:range xsd:decimal ;
                    rdfs:comment "Numeric treatment effect estimate. Include only the estimate, not confidence intervals or textual qualifiers."@en ;
                    rdfs:label "has treatment effect"@en ;
                    :uiExample "-0.18" ;
                    :uiPlaceholder "1.25" ;
                    :uiSection "Submission" .


###  https://erct.adaptcentre.com/ontology#hasTreatmentGroupSize
:hasTreatmentGroupSize rdf:type owl:DatatypeProperty ;
                       rdfs:domain :TreatmentArm ;
                       rdfs:range xsd:integer ;
                       rdfs:comment "Number of observations in the treatment arm."@en ;
                       rdfs:label "has treatment group size"@en .


###  https://erct.adaptcentre.com/ontology#hasType
:hasType rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf :hasName ;
         rdfs:domain :TreatmentVar ;
         rdfs:range xsd:string ;
         rdfs:comment "Legacy property from earlier mapped datasets. Use erct:hasName on controlled concept nodes."@en ;
         rdfs:label "hasType (deprecated)"@en ;
         owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#hasUNSustainableGoal
:hasUNSustainableGoal rdf:type owl:DatatypeProperty ;
                      rdfs:subPropertyOf owl:topDataProperty ;
                      rdfs:label "hasUNSustainableGoal"@en .


###  https://erct.adaptcentre.com/ontology#hasUnit
:hasUnit rdf:type owl:DatatypeProperty ;
         rdfs:domain :Indicator ;
         rdfs:range xsd:string ;
         rdfs:comment "Unit for an indicator value, for example USD or percentage of population."@en ;
         rdfs:label "has unit"@en ;
         :uiSection "Evidence view" .


###  https://erct.adaptcentre.com/ontology#hasValue
:hasValue rdf:type owl:DatatypeProperty ;
          rdfs:domain :Indicator ;
          rdfs:range rdfs:Literal ;
          rdfs:comment "Numeric or literal value of an indicator. Prefer numeric values when available and avoid placeholders such as \\\"None\\\"."@en ;
          rdfs:label "has value"@en ;
          :uiSection "Evidence view" .


###  https://erct.adaptcentre.com/ontology#isControl
:isControl rdf:type owl:DatatypeProperty ;
           rdfs:domain :TreatmentArm ;
           rdfs:range xsd:boolean ;
           rdfs:comment "Boolean flag indicating whether a treatment arm is a control condition."@en ;
           rdfs:label "is control"@en .


###  https://erct.adaptcentre.com/ontology#isPrimaryREsearcher
:isPrimaryREsearcher rdf:type owl:DatatypeProperty ;
                     rdfs:comment "Deprecated misspelling. Use erct:isPrimaryResearcher."@en ;
                     rdfs:label "is primary researcher (deprecated typo)"@en ;
                     owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#isPrimaryResearcher
:isPrimaryResearcher rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Researcher ;
                     rdfs:range xsd:boolean ;
                     rdfs:comment "Boolean flag indicating that the linked researcher is the primary contact."@en ;
                     rdfs:label "is primary researcher"@en .


###  https://erct.adaptcentre.com/ontology#isPublished
:isPublished rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:boolean ;
             rdfs:comment "Boolean flag indicating whether trial results are published."@en ;
             rdfs:label "is published"@en .


###  https://erct.adaptcentre.com/ontology#reviewTimestamp
:reviewTimestamp rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Submission ;
                 rdfs:range xsd:dateTime ;
                 rdfs:comment "Date-time when a submission was reviewed and confirmed by a human reviewer."@en ;
                 rdfs:label "review timestamp"@en ;
                 :uiExample "2026-02-07T15:30:00Z" ;
                 :uiPlaceholder "2026-02-07T15:30:00Z" ;
                 :uiSection "Submission provenance" .


###  https://erct.adaptcentre.com/ontology#usedModelName
:usedModelName rdf:type owl:DatatypeProperty ;
               rdfs:domain :ExtractionRun ;
               rdfs:range xsd:string ;
               rdfs:comment "Name of the model used in an extraction run, such as gpt-4o or gemini-1.5-pro."@en ;
               rdfs:label "used model name"@en ;
               :uiExample "claude-3.5-sonnet" ;
               :uiPlaceholder "gpt-4o" ;
               :uiSection "Extraction provenance" .


###  https://erct.adaptcentre.com/ontology#usedModelVersion
:usedModelVersion rdf:type owl:DatatypeProperty ;
                  rdfs:domain :ExtractionRun ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Version identifier for the model used in extraction."@en ;
                  rdfs:label "used model version"@en ;
                  :uiExample "2024-11-20" ;
                  :uiPlaceholder "2025-01-15" ;
                  :uiSection "Extraction provenance" .


###  https://erct.adaptcentre.com/ontology#State%2FProvince_name
<https://erct.adaptcentre.com/ontology#State%2FProvince_name> rdf:type owl:DatatypeProperty ;
                                                              rdfs:subPropertyOf owl:topDataProperty ;
                                                              rdfs:label "State%2FProvince_name"@en .


#################################################################
#    Classes
#################################################################

###  https://erct.adaptcentre.com/ontology#Agent
:Agent rdf:type owl:Class ;
       rdfs:subClassOf <http://www.w3.org/ns/prov#Agent> ;
       rdfs:comment "A person or organisation involved in generating or conducting trial evidence."@en ;
       rdfs:label "Agent"@en .


###  https://erct.adaptcentre.com/ontology#ClusterUnitType
:ClusterUnitType rdf:type owl:Class ;
                 rdfs:comment "Concept describing the type of cluster used in clustered randomisation, such as village or school."@en ;
                 rdfs:label "Cluster unit type"@en .


###  https://erct.adaptcentre.com/ontology#Clustered
:Clustered rdf:type owl:Class ;
           rdfs:subClassOf :Sampling ;
           rdfs:comment "Sampling approach where randomisation occurs at a group level such as village, school, or district."@en ;
           rdfs:label "Clustered sampling"@en .


###  https://erct.adaptcentre.com/ontology#Country
:Country rdf:type owl:Class ;
         rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ,
                         :Place .


###  https://erct.adaptcentre.com/ontology#EntityWithProvenance
:EntityWithProvenance rdf:type owl:Class ;
                      rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                      rdfs:comment "Any entity tracked with provenance metadata such as attribution, generation time, or generating activity."@en ;
                      rdfs:label "Entity with provenance"@en .


###  https://erct.adaptcentre.com/ontology#EntityWithProvenence
:EntityWithProvenence rdf:type owl:Class ;
                      rdfs:comment "Deprecated misspelling. Use erct:EntityWithProvenance."@en ;
                      rdfs:label "Entity with provenence (deprecated)"@en ;
                      owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#EvaluationMethod
:EvaluationMethod rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> .


###  https://erct.adaptcentre.com/ontology#ExperimentalDesignType
:ExperimentalDesignType rdf:type owl:Class ;
                        rdfs:comment "Legacy class for experimental design terms. Use erct:EvaluationMethod for canonical filterable concepts."@en ;
                        rdfs:label "Experimental design type"@en ;
                        owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#ExternalClassification
:ExternalClassification rdf:type owl:Class ;
                        rdfs:label "ExternalClassification"@en .


###  https://erct.adaptcentre.com/ontology#ExtractionRun
:ExtractionRun rdf:type owl:Class ;
               rdfs:comment "An automated extraction event, such as an LLM run that produced candidate metadata."@en ;
               rdfs:label "Extraction run"@en ;
               :uiExample "LLM extraction run using gpt-4o for Trial 1230" ;
               :uiSection "Extraction provenance" .


###  https://erct.adaptcentre.com/ontology#Finding
:Finding rdf:type owl:Class ;
         rdfs:comment "A reported result from a trial linking an outcome and optionally an estimate and uncertainty to a specific intervention or comparison context."@en ;
         rdfs:label "Finding"@en .


###  https://erct.adaptcentre.com/ontology#Indicator
:Indicator rdf:type owl:Class ;
           rdfs:comment "Contextual indicator associated with countries or trials, for example GDP or HDI values."@en ;
           rdfs:label "Indicator"@en .


###  https://erct.adaptcentre.com/ontology#IngestionMethod
:IngestionMethod rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ;
                 rdfs:comment "Controlled concept describing how metadata was ingested, such as manual entry or LLM-assisted extraction."@en ;
                 rdfs:label "Ingestion method"@en .


###  https://erct.adaptcentre.com/ontology#Intervention
:Intervention rdf:type owl:Class ;
              rdfs:comment "A treatment or program applied in a trial arm."@en ;
              rdfs:label "Intervention"@en .


###  https://erct.adaptcentre.com/ontology#InterventionType
:InterventionType rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> .


###  https://erct.adaptcentre.com/ontology#Method
:Method rdf:type owl:Class ;
        owl:equivalentClass :Methodology ;
        rdfs:comment "Legacy class name from earlier mapped datasets. Use erct:Methodology."@en ;
        rdfs:label "Method (deprecated)"@en ;
        owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#Methodology
:Methodology rdf:type owl:Class ;
             rdfs:comment "Method details for trial design, sampling, power, and related study setup metadata."@en ;
             rdfs:label "Methodology"@en .


###  https://erct.adaptcentre.com/ontology#Outcome
:Outcome rdf:type owl:Class ;
         owl:equivalentClass :TreatmentVar ;
         rdfs:comment "Legacy class name from earlier mapped datasets. Use erct:TreatmentVar."@en ;
         rdfs:label "Outcome (deprecated)"@en ;
         owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#OutcomeDomain
:OutcomeDomain rdf:type owl:Class ;
               rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> .


###  https://erct.adaptcentre.com/ontology#Place
:Place rdf:type owl:Class ;
       rdfs:comment "A geographic entity used for trial location metadata."@en ;
       rdfs:label "Place"@en .


###  https://erct.adaptcentre.com/ontology#ProvenanceActivity
:ProvenanceActivity rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
                    rdfs:comment "An activity that generated, transformed, or informed trial evidence."@en ;
                    rdfs:label "Provenance activity"@en .


###  https://erct.adaptcentre.com/ontology#PublicationInfo
:PublicationInfo rdf:type owl:Class ;
                 owl:equivalentClass :publicationInfo ;
                 rdfs:comment "Legacy class name from earlier mapped datasets. Use erct:publicationInfo."@en ;
                 rdfs:label "PublicationInfo (deprecated)"@en ;
                 owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#Random
:Random rdf:type owl:Class ;
        rdfs:subClassOf :Sampling ;
        rdfs:comment "Deprecated class name. Use erct:Randomized for individual randomisation."@en ;
        rdfs:label "Random (deprecated)"@en ;
        owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#RandomisedControlledTrial
:RandomisedControlledTrial rdf:type owl:Class ;
                           owl:equivalentClass :Trial ;
                           rdfs:comment "A trial study with random assignment to treatment and control conditions."@en ;
                           rdfs:label "Randomised controlled trial"@en .


###  https://erct.adaptcentre.com/ontology#Randomized
:Randomized rdf:type owl:Class ;
            rdfs:subClassOf :Sampling ;
            rdfs:comment "Sampling approach where randomisation is at the individual level."@en ;
            rdfs:label "Randomized sampling"@en .


###  https://erct.adaptcentre.com/ontology#Region
:Region rdf:type owl:Class ;
        rdfs:subClassOf :Place ;
        rdfs:comment "Sub-national place such as a state, province, or district."@en ;
        rdfs:label "Region"@en .


###  https://erct.adaptcentre.com/ontology#Researcher
:Researcher rdf:type owl:Class ;
            rdfs:subClassOf :Agent ;
            rdfs:comment "A person responsible for trial design, execution, or reporting."@en ;
            rdfs:label "Researcher"@en .


###  https://erct.adaptcentre.com/ontology#Sampling
:Sampling rdf:type owl:Class ;
          rdfs:comment "Sampling strategy information for a trial or treatment arm."@en ;
          rdfs:label "Sampling"@en .


###  https://erct.adaptcentre.com/ontology#Sector
:Sector rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> .


###  https://erct.adaptcentre.com/ontology#SourceDocument
:SourceDocument rdf:type owl:Class ;
                rdfs:comment "A document used as extraction input, typically a PDF evaluation report."@en ;
                rdfs:label "Source document"@en ;
                :uiExample "impact_evaluation_report_2024.pdf" ;
                :uiSection "Extraction provenance" .


###  https://erct.adaptcentre.com/ontology#Stratified
:Stratified rdf:type owl:Class ;
            rdfs:subClassOf :Sampling ;
            rdfs:comment "Sampling approach where assignment is stratified by a demographic variable such as gender or geography."@en ;
            rdfs:label "Stratified sampling"@en .


###  https://erct.adaptcentre.com/ontology#Submission
:Submission rdf:type owl:Class ;
            rdfs:comment "An ingestion event representing a user-confirmed submission into the knowledge graph."@en ;
            rdfs:label "Submission"@en ;
            :uiExample "Submission for trial AEARCTR-0001230 confirmed by reviewer" ;
            :uiSection "Submission provenance" .


###  https://erct.adaptcentre.com/ontology#Timespan
:Timespan rdf:type owl:Class ;
          rdfs:comment "Start and end dates associated with a trial or intervention."@en ;
          rdfs:label "Timespan"@en .


###  https://erct.adaptcentre.com/ontology#TreatmentArm
:TreatmentArm rdf:type owl:Class ;
              rdfs:comment "A trial arm representing one treatment or control condition."@en ;
              rdfs:label "Treatment arm"@en .


###  https://erct.adaptcentre.com/ontology#TreatmentVar
:TreatmentVar rdf:type owl:Class ;
              rdfs:comment "Measured treatment effect metadata, including effect size and p-value."@en ;
              rdfs:label "Treatment variable"@en .


###  https://erct.adaptcentre.com/ontology#Trial
:Trial rdf:type owl:Class ;
       owl:equivalentClass :TrialRecord ;
       rdfs:comment "Top-level record used in the UI evidence view and filter facets. One trial may have multiple sectors, countries, intervention types, and outcome domains."@en ;
       rdfs:label "Trial"@en .


###  https://erct.adaptcentre.com/ontology#TrialRecord
:TrialRecord rdf:type owl:Class ;
             rdfs:comment "Legacy class used in existing exports for trial-level rows. Use erct:Trial as the canonical UI-facing class."@en ;
             rdfs:label "Trial record"@en ;
             owl:deprecated "true"^^xsd:boolean .


###  https://erct.adaptcentre.com/ontology#demographicVariable
:demographicVariable rdf:type owl:Class ;
                     rdfs:comment "Variable used for stratification, such as gender or county."@en ;
                     rdfs:label "Demographic variable"@en .


