<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:bibo="http://purl.org/ontology/bibo/"
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:erct="https://erct.adaptcentre.com/ontology#"
   xmlns:foaf="http://xmlns.com/foaf/0.1/"
   xmlns:mod="https://w3id.org/mod#"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
   xmlns:vann="http://purl.org/vocab/vann/"
>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#EvidenceCompletenessScheme">
    <rdfs:comment xml:lang="en">Controlled concept scheme describing whether key evidence fields are complete.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <rdfs:label xml:lang="en">Evidence completeness scheme</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasDOI">
    <erct:uiPlaceholder>10.xxxx/xxxx</erct:uiPlaceholder>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#publicationInfo"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">DOI identifier for a publication. Use canonical DOI format such as 10.1257/rct.1505-3.0.</rdfs:comment>
    <rdfs:label xml:lang="en">has DOI</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <erct:uiExample>10.1257/rct.1505-3.0</erct:uiExample>
    <erct:uiSection>Submission</erct:uiSection>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasISOAlpha2">
    <erct:uiExample>KE</erct:uiExample>
    <erct:uiSection>Exports</erct:uiSection>
    <rdfs:label xml:lang="en">has ISO alpha-2 code</rdfs:label>
    <rdfs:comment xml:lang="en">Two-letter ISO 3166-1 country code used in exports and tabular joins.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Country"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Region">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">Sub-national place such as a state, province, or district.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://erct.adaptcentre.com/ontology#Place"/>
    <rdfs:label xml:lang="en">Region</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasDAC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">hasDAC</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#reviewedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Agent"/>
    <erct:uiSection>Submission provenance</erct:uiSection>
    <rdfs:label xml:lang="en">reviewed by</rdfs:label>
    <rdfs:comment xml:lang="en">Identifies the reviewer who confirmed or edited extracted metadata before acceptance.</rdfs:comment>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Submission"/>
    <erct:uiExample>http://example.org/agent/reviewer-17</erct:uiExample>
    <erct:uiPlaceholder>Reviewer identifier</erct:uiPlaceholder>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasPower">
    <rdfs:label xml:lang="en">has power</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Methodology"/>
    <rdfs:comment xml:lang="en">Statistical power used in study design. Use a decimal probability between 0 and 1 when available.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasProvenanceInfo">
    <rdfs:label xml:lang="en">has provenance information</rdfs:label>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#EntityWithProvenance"/>
    <rdfs:comment xml:lang="en">Links a trial to provenance metadata entities.</rdfs:comment>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#isPrimaryResearcher">
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Researcher"/>
    <rdfs:comment xml:lang="en">Boolean flag indicating that the linked researcher is the primary contact.</rdfs:comment>
    <rdfs:label xml:lang="en">is primary researcher</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Clustered">
    <rdfs:comment xml:lang="en">Sampling approach where randomisation occurs at a group level such as village, school, or district.</rdfs:comment>
    <rdfs:label xml:lang="en">Clustered sampling</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://erct.adaptcentre.com/ontology#Sampling"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#ingestionMethod">
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#IngestionMethod"/>
    <rdfs:comment xml:lang="en">Controlled method describing how the submission metadata was ingested. Use concepts such as erct:ManualIngestion or erct:LLMAssistedIngestion.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <erct:uiSection>Submission provenance</erct:uiSection>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Submission"/>
    <erct:uiExample>erct:LLMAssistedIngestion</erct:uiExample>
    <rdfs:label xml:lang="en">ingestion method</rdfs:label>
    <erct:uiPlaceholder>manual or llm-assisted</erct:uiPlaceholder>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasTitle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">hasTitle (deprecated)</rdfs:label>
    <rdfs:comment xml:lang="en">Legacy property from earlier mapped datasets. Use erct:hasName.</rdfs:comment>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <rdfs:subPropertyOf rdf:resource="https://erct.adaptcentre.com/ontology#hasName"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#publicationInfo"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#performedBy">
    <rdfs:comment xml:lang="en">General relation linking an activity-like entity to the responsible agent.</rdfs:comment>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Agent"/>
    <rdfs:label xml:lang="en">performed by</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#TreatmentVar">
    <rdfs:label xml:lang="en">Treatment variable</rdfs:label>
    <rdfs:comment xml:lang="en">Measured treatment effect metadata, including effect size and p-value.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Stratified">
    <rdfs:comment xml:lang="en">Sampling approach where assignment is stratified by a demographic variable such as gender or geography.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://erct.adaptcentre.com/ontology#Sampling"/>
    <rdfs:label xml:lang="en">Stratified sampling</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasISOAlpha3">
    <erct:uiSection>Exports</erct:uiSection>
    <rdfs:comment xml:lang="en">Three-letter ISO 3166-1 country code used in external data integration.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Country"/>
    <erct:uiExample>KEN</erct:uiExample>
    <rdfs:label xml:lang="en">has ISO alpha-3 code</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasExternalClassification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasExternalClassification</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#ExternalClassification"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasMDE">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <erct:uiSection>Submission</erct:uiSection>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Methodology"/>
    <erct:uiExample>0.15</erct:uiExample>
    <rdfs:comment xml:lang="en">Minimum detectable effect value reported in methodology metadata. Valid input is numeric.</rdfs:comment>
    <erct:uiPlaceholder>0.2</erct:uiPlaceholder>
    <rdfs:label xml:lang="en">has minimum detectable effect</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Submission">
    <erct:uiExample>Submission for trial AEARCTR-0001230 confirmed by reviewer</erct:uiExample>
    <rdfs:comment xml:lang="en">An ingestion event representing a user-confirmed submission into the knowledge graph.</rdfs:comment>
    <rdfs:label xml:lang="en">Submission</rdfs:label>
    <erct:uiSection>Submission provenance</erct:uiSection>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasEvidenceCompleteness">
    <rdfs:label xml:lang="en">has evidence completeness</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Finding"/>
    <rdfs:comment xml:lang="en">Links a finding to a controlled completeness status. Values should be skos:Concept in erct:EvidenceCompletenessScheme.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasMethod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">hasMethod (deprecated)</rdfs:label>
    <rdfs:comment xml:lang="en">Legacy property from earlier mapped datasets. Use erct:hasMethodology.</rdfs:comment>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <rdfs:subPropertyOf rdf:resource="https://erct.adaptcentre.com/ontology#hasMethodology"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Methodology"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasTimespan">
    <rdfs:comment xml:lang="en">Links a trial, intervention, or treatment arm to a start and end date container.</rdfs:comment>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Timespan"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has timespan</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasOutcomeDomain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment xml:lang="en">Facet property for broad outcome domain. Canonical values are controlled IRIs of skos:Concept in erct:OutcomeDomainScheme, such as health or income. Legacy data may contain literal values. Pipelines should migrate or align literals to controlled concept IRIs via skos:altLabel or erct:legacyLiteralValue.</rdfs:comment>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
    <rdfs:label xml:lang="en">has outcome domain</rdfs:label>
    <erct:uiPlaceholder>Select outcome domain</erct:uiPlaceholder>
    <erct:uiSection>Filters</erct:uiSection>
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <erct:uiExample>http://example.org/outcome/income</erct:uiExample>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#EvidenceType_RegistryEntry">
    <skos:prefLabel xml:lang="en">Registry entry</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#EvidenceTypeScheme"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#OutcomeDomainScheme">
    <rdfs:label xml:lang="en">Outcome domain scheme</rdfs:label>
    <rdfs:comment xml:lang="en">Controlled concept scheme for outcome domain facet values.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#OutcomeDomain_Income">
    <skos:altLabel xml:lang="en">Earnings</skos:altLabel>
    <skos:altLabel xml:lang="en">Household income</skos:altLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#OutcomeDomainScheme"/>
    <skos:prefLabel xml:lang="en">Income</skos:prefLabel>
    <rdfs:comment xml:lang="en">Example outcome domain concept with common synonym variants.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#usedModelName">
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#ExtractionRun"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <erct:uiSection>Extraction provenance</erct:uiSection>
    <rdfs:label xml:lang="en">used model name</rdfs:label>
    <erct:uiExample>claude-3.5-sonnet</erct:uiExample>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment xml:lang="en">Name of the model used in an extraction run, such as gpt-4o or gemini-1.5-pro.</rdfs:comment>
    <erct:uiPlaceholder>gpt-4o</erct:uiPlaceholder>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Outcome">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Outcome (deprecated)</rdfs:label>
    <rdfs:comment xml:lang="en">Legacy class name from earlier mapped datasets. Use erct:TreatmentVar.</rdfs:comment>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <owl:equivalentClass rdf:resource="https://erct.adaptcentre.com/ontology#TreatmentVar"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#CountryScheme">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <rdfs:comment xml:lang="en">Controlled concept scheme for country facet values.</rdfs:comment>
    <rdfs:label xml:lang="en">Country scheme</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Pre-Registration">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Pre-Registration</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasControlGroupSize">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#TreatmentArm"/>
    <rdfs:label xml:lang="en">has control group size</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment xml:lang="en">Number of observations in the control arm.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#ExperimentalDesignType">
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Experimental design type</rdfs:label>
    <rdfs:comment xml:lang="en">Legacy class for experimental design terms. Use erct:EvaluationMethod for canonical filterable concepts.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#EvaluationMethod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:comment xml:lang="en">Controlled concept for evaluation design or methodology facets, for example stratified randomisation.</rdfs:comment>
    <skos:prefLabel xml:lang="en">Evaluation method</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:label xml:lang="en">Evaluation method</rdfs:label>
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#EvaluationMethodScheme"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasEmail">
    <erct:uiSection>Submission</erct:uiSection>
    <erct:uiPlaceholder>name@example.org</erct:uiPlaceholder>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Researcher"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="en">has email</rdfs:label>
    <erct:uiExample>j.doe@university.edu</erct:uiExample>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment xml:lang="en">Email address for a researcher contact. Valid input should be a single email address; avoid adding names, labels, or multiple addresses in one value.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#aboutIntervention">
    <rdfs:comment xml:lang="en">Links a finding to the intervention context that the reported result is about.</rdfs:comment>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Finding"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">about intervention</rdfs:label>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Intervention"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasInterventionType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has intervention type</rdfs:label>
    <erct:uiSection>Filters</erct:uiSection>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
    <erct:uiPlaceholder>Select intervention type</erct:uiPlaceholder>
    <rdfs:comment xml:lang="en">Facet property for intervention category. Canonical values are controlled IRIs of skos:Concept in erct:InterventionTypeScheme. Legacy data may contain literal values. Pipelines should migrate or align literals to controlled concept IRIs via skos:altLabel or erct:legacyLiteralValue.</rdfs:comment>
    <erct:uiExample>http://example.org/intervention/conditional_cash_transfer</erct:uiExample>
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology">
    <owl:versionIRI rdf:resource="https://erct.adaptcentre.com/ontology/5.0.0"/>
    <vann:preferredNamespacePrefix>erct</vann:preferredNamespacePrefix>
    <owl:versionInfo>5.0.0</owl:versionInfo>
    <owl:imports rdf:resource="http://www.w3.org/ns/prov-o"/>
    <owl:imports rdf:resource="http://www.w3.org/2004/02/skos/core"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-07</dcterms:issued>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:label xml:lang="en">Evidence from Randomised Controlled Trials Ontology</rdfs:label>
    <dcterms:identifier rdf:resource="https://doi.org/10.5281/zenodo.10993684"/>
    <foaf:logo rdf:resource="https://zenodo.org/badge/DOI/10.5281/zenodo.10993684.svg"/>
    <dcterms:creator xml:lang="en">ERCT project team</dcterms:creator>
    <rdfs:comment xml:lang="en">Adds Finding-level evidence units and strengthens SKOS lexical coverage for robust search and filtering; does not model interaction logs or user trust measures.</rdfs:comment>
    <rdfs:comment xml:lang="en">ERCT models randomised controlled trial evidence for search, filtering, submission, and export workflows.</rdfs:comment>
    <mod:status>active</mod:status>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-07</dcterms:created>
    <dcterms:source xml:lang="en">ERCT ontology source distribution</dcterms:source>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
    <dcterms:bibliographicCitation xml:lang="en">Evidence from Randomised Controlled Trials Ontology (ERCT), version 5.0.0.</dcterms:bibliographicCitation>
    <dcterms:title xml:lang="en">Evidence from Randomised Controlled Trials Ontology</dcterms:title>
    <bibo:doi>10.5281/zenodo.10993684</bibo:doi>
    <dcterms:publisher xml:lang="en">ERCT project</dcterms:publisher>
    <vann:preferredNamespaceUri>https://erct.adaptcentre.com/ontology#</vann:preferredNamespaceUri>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#isPrimaryREsearcher">
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <rdfs:label xml:lang="en">is primary researcher (deprecated typo)</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment xml:lang="en">Deprecated misspelling. Use erct:isPrimaryResearcher.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Finding">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">A reported result from a trial linking an outcome and optionally an estimate and uncertainty to a specific intervention or comparison context.</rdfs:comment>
    <rdfs:label xml:lang="en">Finding</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasEvidenceType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Finding"/>
    <rdfs:comment xml:lang="en">Links a finding to the type of supporting evidence source. Values should be skos:Concept in erct:EvidenceTypeScheme.</rdfs:comment>
    <rdfs:label xml:lang="en">has evidence type</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasFindingOutcomeDomain">
    <rdfs:comment xml:lang="en">Links a finding to an outcome-domain concept. Values should be skos:Concept in erct:OutcomeDomainScheme. Legacy literal values may exist and require alignment during ingestion.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Finding"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has finding outcome domain</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Timespan">
    <rdfs:comment xml:lang="en">Start and end dates associated with a trial or intervention.</rdfs:comment>
    <rdfs:label xml:lang="en">Timespan</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasTreatmentArm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#TreatmentArm"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
    <rdfs:label xml:lang="en">has treatment arm</rdfs:label>
    <rdfs:comment xml:lang="en">Links a trial to one or more treatment arms.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#OutcomeDomain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#OutcomeDomainScheme"/>
    <skos:prefLabel xml:lang="en">Outcome domain</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:label xml:lang="en">Outcome domain</rdfs:label>
    <rdfs:comment xml:lang="en">Controlled concept for domains of measured outcomes such as income, health, education, or behavior.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#extractedFromDocument">
    <erct:uiSection>Extraction provenance</erct:uiSection>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#SourceDocument"/>
    <erct:uiPlaceholder>Link to source document IRI</erct:uiPlaceholder>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment xml:lang="en">Identifies the source document used for automated extraction.</rdfs:comment>
    <rdfs:label xml:lang="en">extracted from document</rdfs:label>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#ExtractionRun"/>
    <erct:uiExample>http://example.org/document/impact-eval-2024-pdf</erct:uiExample>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#generatedBy">
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#EntityWithProvenance"/>
    <rdfs:comment xml:lang="en">Links an evidence entity to the activity that generated it.</rdfs:comment>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#ProvenanceActivity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">generated by</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasGeneratedBy"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasEndDate">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:comment xml:lang="en">End date for trial implementation. Use ISO date format YYYY-MM-DD when possible.</rdfs:comment>
    <erct:uiPlaceholder>2023-06-30</erct:uiPlaceholder>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <erct:uiExample>2022-12-31</erct:uiExample>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Timespan"/>
    <erct:uiSection>Submission</erct:uiSection>
    <rdfs:label xml:lang="en">has end date</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#clusteredBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment xml:lang="en">Specifies cluster unit type for clustered sampling, for example village, school, or district.</rdfs:comment>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#ClusterUnitType"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Clustered"/>
    <rdfs:label xml:lang="en">clustered by</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Randomized">
    <rdfs:label xml:lang="en">Randomized sampling</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">Sampling approach where randomisation is at the individual level.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://erct.adaptcentre.com/ontology#Sampling"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">hasType (deprecated)</rdfs:label>
    <rdfs:comment xml:lang="en">Legacy property from earlier mapped datasets. Use erct:hasName on controlled concept nodes.</rdfs:comment>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <rdfs:subPropertyOf rdf:resource="https://erct.adaptcentre.com/ontology#hasName"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#TreatmentVar"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasExtractionRun">
    <rdfs:comment xml:lang="en">Links a submission to the extraction run used to pre-populate metadata.</rdfs:comment>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Submission"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#ExtractionRun"/>
    <erct:uiPlaceholder>Link to extraction run IRI</erct:uiPlaceholder>
    <erct:uiExample>http://example.org/extraction/run-2026-02-07-01</erct:uiExample>
    <erct:uiSection>Extraction provenance</erct:uiSection>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has extraction run</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#RandomisedControlledTrial">
    <rdfs:comment xml:lang="en">A trial study with random assignment to treatment and control conditions.</rdfs:comment>
    <rdfs:label xml:lang="en">Randomised controlled trial</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasIndicator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment xml:lang="en">Links a country to one or more contextual indicators used in evidence exploration and exports.</rdfs:comment>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Country"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Indicator"/>
    <rdfs:label xml:lang="en">has indicator</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Country">
    <skos:prefLabel xml:lang="en">Country</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:subClassOf rdf:resource="https://erct.adaptcentre.com/ontology#Place"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#CountryScheme"/>
    <rdfs:comment xml:lang="en">Country concept used in filtering and evidence context. Values can link to ISO or external geography schemes.</rdfs:comment>
    <rdfs:label xml:lang="en">Country</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasEffectEstimate">
    <rdfs:label xml:lang="en">has effect estimate</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment xml:lang="en">Primary effect estimate at finding level for export and cross-trial synthesis. When a linked treatment variable exists, values should be aligned.</rdfs:comment>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Finding"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#generatedAtTime">
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Timespan"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#EntityWithProvenance"/>
    <rdfs:comment xml:lang="en">Deprecated legacy object property linking to erct:Timespan. Use prov:generatedAtTime with an xsd:dateTime literal for canonical provenance timestamps.</rdfs:comment>
    <rdfs:label xml:lang="en">generated at time (deprecated)</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#attributedTo">
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasAttributedTo"/>
    <rdfs:label xml:lang="en">attributed to</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Agent"/>
    <rdfs:comment xml:lang="en">Links an evidence entity to the responsible agent.</rdfs:comment>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#EntityWithProvenance"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Additional_Dataset_Information">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Additional_Dataset_Information</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#SectorScheme">
    <rdfs:label xml:lang="en">Sector scheme</rdfs:label>
    <rdfs:comment xml:lang="en">Controlled concept scheme for sector facet values.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#SourceDocument">
    <rdfs:comment xml:lang="en">A document used as extraction input, typically a PDF evaluation report.</rdfs:comment>
    <erct:uiSection>Extraction provenance</erct:uiSection>
    <rdfs:label xml:lang="en">Source document</rdfs:label>
    <erct:uiExample>impact_evaluation_report_2024.pdf</erct:uiExample>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Sector">
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#SectorScheme"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Sector</skos:prefLabel>
    <rdfs:label xml:lang="en">Sector</rdfs:label>
    <rdfs:comment xml:lang="en">Controlled concept for trial sector facets, for example health, education, agriculture, or governance.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Agent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Agent</rdfs:label>
    <rdfs:comment xml:lang="en">A person or organisation involved in generating or conducting trial evidence.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Agent"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#conductedBy">
    <rdfs:comment xml:lang="en">Links a trial to the researcher who conducted it.</rdfs:comment>
    <rdfs:label xml:lang="en">conducted by</rdfs:label>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Researcher"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasExperimentalDesignType">
    <rdfs:comment xml:lang="en">Deprecated ambiguous facet-like property. Use erct:hasEvaluationMethod for filtering and erct:hasMethodology for structured methodology nodes.</rdfs:comment>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#EvaluationMethod"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Methodology"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <rdfs:label xml:lang="en">has experimental design type (deprecated)</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasUnit">
    <rdfs:label xml:lang="en">has unit</rdfs:label>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Indicator"/>
    <rdfs:comment xml:lang="en">Unit for an indicator value, for example USD or percentage of population.</rdfs:comment>
    <erct:uiSection>Evidence view</erct:uiSection>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasFinding">
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Finding"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
    <rdfs:label xml:lang="en">has finding</rdfs:label>
    <rdfs:comment xml:lang="en">Links a trial to a finding-level unit of reported evidence used for citation and comparison.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Keywords">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Keywords</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Open_Access">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Open_Access</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#reviewTimestamp">
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Submission"/>
    <rdfs:comment xml:lang="en">Date-time when a submission was reviewed and confirmed by a human reviewer.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <erct:uiExample>2026-02-07T15:30:00Z</erct:uiExample>
    <erct:uiPlaceholder>2026-02-07T15:30:00Z</erct:uiPlaceholder>
    <rdfs:label xml:lang="en">review timestamp</rdfs:label>
    <erct:uiSection>Submission provenance</erct:uiSection>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Equity_focus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Equity_focus</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Project_name">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Project_name</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasStartDate">
    <erct:uiExample>2020-01-15</erct:uiExample>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment xml:lang="en">Start date for trial implementation. Use ISO date format YYYY-MM-DD when possible.</rdfs:comment>
    <rdfs:label xml:lang="en">has start date</rdfs:label>
    <erct:uiPlaceholder>2021-09-01</erct:uiPlaceholder>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Timespan"/>
    <erct:uiSection>Submission</erct:uiSection>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasUNSustainableGoal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">hasUNSustainableGoal</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Intervention">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">A treatment or program applied in a trial arm.</rdfs:comment>
    <rdfs:label xml:lang="en">Intervention</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasTreatmentVariable">
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#TreatmentVar"/>
    <rdfs:label xml:lang="en">has treatment variable</rdfs:label>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Finding"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment xml:lang="en">Links a finding to the treatment-variable node containing effect-size and p-value details.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasFindingProvenanceInfo">
    <rdfs:comment xml:lang="en">Links a finding to provenance metadata entities using the same provenance model applied at trial level.</rdfs:comment>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Finding"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#EntityWithProvenance"/>
    <rdfs:label xml:lang="en">has finding provenance information</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#used">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#EntityWithProvenance"/>
    <rdfs:comment xml:lang="en">Indicates that a provenance activity used a prior evidence entity as input.</rdfs:comment>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#ProvenanceActivity"/>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#used"/>
    <rdfs:label xml:lang="en">used</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Random">
    <rdfs:subClassOf rdf:resource="https://erct.adaptcentre.com/ontology#Sampling"/>
    <rdfs:comment xml:lang="en">Deprecated class name. Use erct:Randomized for individual randomisation.</rdfs:comment>
    <rdfs:label xml:lang="en">Random (deprecated)</rdfs:label>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#usedModelVersion">
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#ExtractionRun"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <erct:uiExample>2024-11-20</erct:uiExample>
    <rdfs:comment xml:lang="en">Version identifier for the model used in extraction.</rdfs:comment>
    <erct:uiSection>Extraction provenance</erct:uiSection>
    <rdfs:label xml:lang="en">used model version</rdfs:label>
    <erct:uiPlaceholder>2025-01-15</erct:uiPlaceholder>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasJELcode">
    <rdfs:label xml:lang="en">has JEL code</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <erct:uiPlaceholder>I25, O12</erct:uiPlaceholder>
    <erct:uiExample>H43</erct:uiExample>
    <rdfs:comment xml:lang="en">JEL code list for trial publications. Use standard JEL codes such as I25 or O12, separated consistently in data-entry workflows.</rdfs:comment>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#publicationInfo"/>
    <erct:uiSection>Submission</erct:uiSection>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasPValue">
    <rdfs:label xml:lang="en">has p-value</rdfs:label>
    <erct:uiExample>0.012</erct:uiExample>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#TreatmentVar"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment xml:lang="en">P-value associated with a treatment estimate. Valid input is a decimal number between 0 and 1.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <erct:uiSection>Submission</erct:uiSection>
    <erct:uiPlaceholder>0.05</erct:uiPlaceholder>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#ProvenanceActivity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">An activity that generated, transformed, or informed trial evidence.</rdfs:comment>
    <rdfs:label xml:lang="en">Provenance activity</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#takesPlaceIn">
    <rdfs:comment xml:lang="en">Links an intervention or treatment arm to a place where it occurs.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Place"/>
    <rdfs:label xml:lang="en">takes place in</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasMethodology">
    <rdfs:comment xml:lang="en">Links a trial to detailed methodology metadata nodes.</rdfs:comment>
    <rdfs:label xml:lang="en">has methodology</rdfs:label>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Methodology"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasSubmission">
    <erct:uiPlaceholder>Link to submission event IRI</erct:uiPlaceholder>
    <erct:uiSection>Submission provenance</erct:uiSection>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Submission"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
    <erct:uiExample>http://example.org/submission/aea-1230-2026-02-07</erct:uiExample>
    <rdfs:label xml:lang="en">has submission</rdfs:label>
    <rdfs:comment xml:lang="en">Links a trial record to the submission event that created or updated it.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Primary_Dataset_Availability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Primary_Dataset_Availability</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasSampleSize">
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Sampling"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment xml:lang="en">Total number of observations used in the analysis. Valid input is an integer count. Avoid free text values such as "about 200" or missing-value tokens such as N/A.</rdfs:comment>
    <erct:uiSection>Submission</erct:uiSection>
    <erct:uiExample>850</erct:uiExample>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <erct:uiPlaceholder>1200</erct:uiPlaceholder>
    <rdfs:label xml:lang="en">has sample size</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Indicator">
    <rdfs:label xml:lang="en">Indicator</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">Contextual indicator associated with countries or trials, for example GDP or HDI values.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasSampling">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Sampling"/>
    <rdfs:comment xml:lang="en">Links a trial or methodology node to sampling metadata.</rdfs:comment>
    <rdfs:label xml:lang="en">has sampling</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasEvaluationMethod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
    <erct:uiExample>http://example.org/method/stratified_randomization</erct:uiExample>
    <rdfs:label xml:lang="en">has evaluation method</rdfs:label>
    <erct:uiPlaceholder>Select evaluation method</erct:uiPlaceholder>
    <erct:uiSection>Filters</erct:uiSection>
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:comment xml:lang="en">Facet property for evaluation design or methodology. Canonical values are controlled IRIs of skos:Concept in erct:EvaluationMethodScheme, for example individual randomization or stratified randomization. Legacy data may contain literal values. Pipelines should migrate or align literals to controlled concept IRIs via skos:altLabel or erct:legacyLiteralValue.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Methodology">
    <rdfs:comment xml:lang="en">Method details for trial design, sampling, power, and related study setup metadata.</rdfs:comment>
    <rdfs:label xml:lang="en">Methodology</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#EvidenceCompleteness_MissingKeyFields">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#EvidenceCompletenessScheme"/>
    <skos:prefLabel xml:lang="en">Missing key fields</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Secondary_Dataset_Name">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Secondary_Dataset_Name</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#demographicVariable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Demographic variable</rdfs:label>
    <rdfs:comment xml:lang="en">Variable used for stratification, such as gender or county.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Authors">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Authors</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#PublicationInfo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">PublicationInfo (deprecated)</rdfs:label>
    <rdfs:comment xml:lang="en">Legacy class name from earlier mapped datasets. Use erct:publicationInfo.</rdfs:comment>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <owl:equivalentClass rdf:resource="https://erct.adaptcentre.com/ontology#publicationInfo"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasNoOfClusters">
    <erct:uiSection>Submission</erct:uiSection>
    <erct:uiPlaceholder>64</erct:uiPlaceholder>
    <rdfs:label xml:lang="en">has number of clusters</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:comment xml:lang="en">Number of clusters used in clustered randomisation. Valid input is a numeric count only; do not include unit words in the same field.</rdfs:comment>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Clustered"/>
    <erct:uiExample>120</erct:uiExample>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Protocol_Pre-Analysis_Plan">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Protocol_Pre-Analysis_Plan</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasTreatmentVar">
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#TreatmentArm"/>
    <rdfs:comment xml:lang="en">Links a treatment arm to treatment-effect metadata.</rdfs:comment>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#TreatmentVar"/>
    <rdfs:label xml:lang="en">has treatment variable</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasTreatmentEffect">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <erct:uiExample>-0.18</erct:uiExample>
    <rdfs:comment xml:lang="en">Numeric treatment effect estimate. Include only the estimate, not confidence intervals or textual qualifiers.</rdfs:comment>
    <erct:uiPlaceholder>1.25</erct:uiPlaceholder>
    <rdfs:label xml:lang="en">has treatment effect</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <erct:uiSection>Submission</erct:uiSection>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#TreatmentVar"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasIndicatorType">
    <rdfs:comment xml:lang="en">Human-readable type of indicator, for example HDI, GDP, or net savings.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <erct:uiSection>Evidence view</erct:uiSection>
    <rdfs:label xml:lang="en">has indicator type</rdfs:label>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Indicator"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#InterventionType">
    <rdfs:label xml:lang="en">Intervention type</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#InterventionTypeScheme"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Intervention type</skos:prefLabel>
    <rdfs:comment xml:lang="en">Controlled concept describing intervention categories used in filters and summaries.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasISO">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <erct:uiExample>ZM-02</erct:uiExample>
    <rdfs:comment xml:lang="en">Generic ISO-like code for region records in exports, for example subdivision codes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Region"/>
    <rdfs:label xml:lang="en">has ISO code</rdfs:label>
    <erct:uiSection>Exports</erct:uiSection>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Abstract">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Abstract</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasTreatmentGroupSize">
    <rdfs:label xml:lang="en">has treatment group size</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#TreatmentArm"/>
    <rdfs:comment xml:lang="en">Number of observations in the treatment arm.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#InterventionTypeScheme">
    <rdfs:comment xml:lang="en">Controlled concept scheme for intervention type facet values.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <rdfs:label xml:lang="en">Intervention type scheme</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#EvaluationMethodScheme">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <rdfs:label xml:lang="en">Evaluation method scheme</rdfs:label>
    <rdfs:comment xml:lang="en">Controlled concept scheme for evaluation method facet values.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Trial">
    <owl:equivalentClass rdf:resource="https://erct.adaptcentre.com/ontology#RandomisedControlledTrial"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">Top-level record used in the UI evidence view and filter facets. One trial may have multiple sectors, countries, intervention types, and outcome domains.</rdfs:comment>
    <rdfs:label xml:lang="en">Trial</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#uiSection">
    <rdfs:comment xml:lang="en">Optional UI hint indicating where a field appears in forms or filter panels.</rdfs:comment>
    <rdfs:label xml:lang="en">UI section</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Unit_of_observation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Unit_of_observation</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#EvidenceType_SecondarySummary">
    <skos:prefLabel xml:lang="en">Secondary summary</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#EvidenceTypeScheme"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#ExtractionRun">
    <erct:uiSection>Extraction provenance</erct:uiSection>
    <erct:uiExample>LLM extraction run using gpt-4o for Trial 1230</erct:uiExample>
    <rdfs:label xml:lang="en">Extraction run</rdfs:label>
    <rdfs:comment xml:lang="en">An automated extraction event, such as an LLM run that produced candidate metadata.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Researcher">
    <rdfs:label xml:lang="en">Researcher</rdfs:label>
    <rdfs:comment xml:lang="en">A person responsible for trial design, execution, or reporting.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://erct.adaptcentre.com/ontology#Agent"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#extractionTimestamp">
    <rdfs:label xml:lang="en">extraction timestamp</rdfs:label>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#ExtractionRun"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdfs:comment xml:lang="en">Date-time when the extraction run generated candidate metadata.</rdfs:comment>
    <erct:uiExample>2026-02-07T15:20:00Z</erct:uiExample>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <erct:uiSection>Extraction provenance</erct:uiSection>
    <erct:uiPlaceholder>2026-02-07T15:20:00Z</erct:uiPlaceholder>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#statifiedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment xml:lang="en">Deprecated misspelling. Use erct:stratifiedBy.</rdfs:comment>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <rdfs:label xml:lang="en">statified by (deprecated typo)</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasConfidenceIntervalLower">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <rdfs:comment xml:lang="en">Lower bound of the confidence interval for a finding effect estimate.</rdfs:comment>
    <rdfs:label xml:lang="en">has confidence interval lower</rdfs:label>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Finding"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#EvidenceCompleteness_Complete">
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#EvidenceCompletenessScheme"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Complete</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Program_funding_agency">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Program_funding_agency</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#isControl">
    <rdfs:comment xml:lang="en">Boolean flag indicating whether a treatment arm is a control condition.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#TreatmentArm"/>
    <rdfs:label xml:lang="en">is control</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#EvidenceType_TrialReport">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#EvidenceTypeScheme"/>
    <skos:prefLabel xml:lang="en">Trial report</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Sampling">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">Sampling strategy information for a trial or treatment arm.</rdfs:comment>
    <rdfs:label xml:lang="en">Sampling</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Primary_Dataset_Format">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Primary_Dataset_Format</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Countries">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Countries</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#EvaluationMethod_StratifiedRandomization">
    <skos:prefLabel xml:lang="en">Stratified randomization</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#EvaluationMethodScheme"/>
    <rdfs:comment xml:lang="en">Example evaluation method concept with spelling and phrasing variants.</rdfs:comment>
    <skos:altLabel xml:lang="en">Stratified randomisation</skos:altLabel>
    <skos:altLabel xml:lang="en">Stratified design</skos:altLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Country_KE">
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#CountryScheme"/>
    <rdfs:comment xml:lang="en">Example country concept with code and long-name lexical variants.</rdfs:comment>
    <skos:altLabel xml:lang="en">Republic of Kenya</skos:altLabel>
    <skos:altLabel xml:lang="en">KE</skos:altLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Kenya</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Sector_Health">
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#SectorScheme"/>
    <skos:altLabel xml:lang="en">Health sector</skos:altLabel>
    <skos:altLabel xml:lang="en">Public health</skos:altLabel>
    <rdfs:comment xml:lang="en">Example sector concept with lexical variants for robust filtering.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Health</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Mixed_method">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Mixed_method</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasPublicationDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <erct:uiExample>2023-06-15</erct:uiExample>
    <erct:uiSection>Submission</erct:uiSection>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:label xml:lang="en">has publication date</rdfs:label>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#publicationInfo"/>
    <erct:uiPlaceholder>2024-10-01</erct:uiPlaceholder>
    <rdfs:comment xml:lang="en">Publication date for trial outputs. Use ISO date format YYYY-MM-DD.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#uiPlaceholder">
    <rdfs:comment xml:lang="en">Optional UI hint for placeholder text shown in a form field.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en">UI placeholder</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Place">
    <rdfs:comment xml:lang="en">A geographic entity used for trial location metadata.</rdfs:comment>
    <rdfs:label xml:lang="en">Place</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#TrialRecord">
    <rdfs:label xml:lang="en">Trial record</rdfs:label>
    <owl:equivalentClass rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
    <rdfs:comment xml:lang="en">Legacy class used in existing exports for trial-level rows. Use erct:Trial as the canonical UI-facing class.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasublicationInfo">
    <rdfs:comment xml:lang="en">Deprecated typo from earlier mappings. Use erct:hasPublicationInfo.</rdfs:comment>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <rdfs:label xml:lang="en">has publication information (deprecated typo)</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasSector">
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
    <erct:uiPlaceholder>Select one or more sectors</erct:uiPlaceholder>
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <erct:uiSection>Filters</erct:uiSection>
    <rdfs:label xml:lang="en">has sector</rdfs:label>
    <rdfs:comment xml:lang="en">Facet property used by the UI to filter trials by sector. Canonical values are controlled IRIs of skos:Concept in erct:SectorScheme. Legacy data may contain literal values. Pipelines should migrate or align literals to controlled concept IRIs via skos:altLabel or erct:legacyLiteralValue.</rdfs:comment>
    <erct:uiExample>http://example.org/sector/health</erct:uiExample>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Equity_dimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Equity_dimension</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasValue">
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment xml:lang="en">Numeric or literal value of an indicator. Prefer numeric values when available and avoid placeholders such as \"None\".</rdfs:comment>
    <rdfs:label xml:lang="en">has value</rdfs:label>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Indicator"/>
    <erct:uiSection>Evidence view</erct:uiSection>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasConfidenceIntervalUpper">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Finding"/>
    <rdfs:comment xml:lang="en">Upper bound of the confidence interval for a finding effect estimate.</rdfs:comment>
    <rdfs:label xml:lang="en">has confidence interval upper</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Evaluation_design">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Evaluation_design</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#locatedIn">
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Region"/>
    <rdfs:comment xml:lang="en">Links a sub-national place such as a region to its parent country.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">located in</rdfs:label>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Country"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#State%2FProvince_name">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">State%2FProvince_name</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Research_funding_agency">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Research_funding_agency</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#legacyLiteralValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en">legacy literal value</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Legacy literal encoding for a controlled concept. Use this as an alignment hook when migrating literal facet values to concept IRIs.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasProvenenceInfo">
    <rdfs:comment xml:lang="en">Deprecated misspelling. Use erct:hasProvenanceInfo.</rdfs:comment>
    <rdfs:label xml:lang="en">has provenence information (deprecated typo)</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasPublicationInfo">
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
    <rdfs:label xml:lang="en">has publication information</rdfs:label>
    <rdfs:comment xml:lang="en">Links a trial to bibliographic metadata such as DOI and JEL codes.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#publicationInfo"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#wasInformedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment xml:lang="en">Relates a provenance activity to another provenance activity that informed it.</rdfs:comment>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasInformedBy"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#ProvenanceActivity"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#ProvenanceActivity"/>
    <rdfs:label xml:lang="en">was informed by</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Method">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Method (deprecated)</rdfs:label>
    <rdfs:comment xml:lang="en">Legacy class name from earlier mapped datasets. Use erct:Methodology.</rdfs:comment>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <owl:equivalentClass rdf:resource="https://erct.adaptcentre.com/ontology#Methodology"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasAffiliation">
    <rdfs:label xml:lang="en">has affiliation</rdfs:label>
    <rdfs:comment xml:lang="en">Institutional affiliation for a researcher.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Researcher"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#publicationInfo">
    <rdfs:label xml:lang="en">Publication information</rdfs:label>
    <rdfs:comment xml:lang="en">Bibliographic metadata for trial outputs such as DOI and JEL codes.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#IngestionMethod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Ingestion method</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:comment xml:lang="en">Controlled concept describing how metadata was ingested, such as manual entry or LLM-assisted extraction.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#LLMAssistedIngestion">
    <rdfs:label xml:lang="en">LLM-assisted ingestion</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://erct.adaptcentre.com/ontology#IngestionMethod"/>
    <rdfs:comment xml:lang="en">Metadata pre-populated using an LLM extraction run before human confirmation.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#InterventionType_CashTransfer">
    <skos:prefLabel xml:lang="en">Cash transfer</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:comment xml:lang="en">Example intervention type concept with shorthand and expanded labels.</rdfs:comment>
    <skos:altLabel xml:lang="en">CCT</skos:altLabel>
    <skos:altLabel xml:lang="en">Conditional cash transfer</skos:altLabel>
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#InterventionTypeScheme"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#tookPlaceIn">
    <rdfs:label xml:lang="en">took place in (deprecated)</rdfs:label>
    <rdfs:comment xml:lang="en">Deprecated legacy spelling. Use erct:takesPlaceIn for event location and erct:hasCountry for trial filtering.</rdfs:comment>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#CRS_Voluntary_DAC_Code">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">CRS_Voluntary_DAC_Code</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasName">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="en">has name</rdfs:label>
    <rdfs:comment xml:lang="en">Human-readable display name for an entity.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasIntervention">
    <rdfs:comment xml:lang="en">Links a trial or treatment arm to an intervention instance.</rdfs:comment>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#Intervention"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has intervention</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Implementation_agency">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Implementation_agency</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasOutcome">
    <rdfs:comment xml:lang="en">Free-text outcome description captured from source records. Use erct:hasOutcomeDomain for filterable controlled categorisation.</rdfs:comment>
    <erct:uiPlaceholder>Primary school enrollment rate</erct:uiPlaceholder>
    <erct:uiSection>Submission</erct:uiSection>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="en">has outcome text</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Intervention"/>
    <erct:uiExample>Voter turnout</erct:uiExample>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#uiExample">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:comment xml:lang="en">Optional UI hint showing a representative example value.</rdfs:comment>
    <rdfs:label xml:lang="en">UI example</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/ns/prov#generatedAtTime">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#EntityWithProvenance"/>
    <rdfs:comment xml:lang="en">Canonical provenance timestamp for when an evidence entity was generated. Use xsd:dateTime literals, for example 2026-02-09T10:30:00Z.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">generated at time</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasAbstract">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">hasAbstract</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#EvidenceType_Dataset">
    <skos:prefLabel xml:lang="en">Dataset</skos:prefLabel>
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#EvidenceTypeScheme"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#hasCountry">
    <rdfs:label xml:lang="en">has country</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <erct:uiExample>http://example.org/country/KE</erct:uiExample>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <erct:uiPlaceholder>Select one or more countries</erct:uiPlaceholder>
    <rdfs:comment xml:lang="en">Facet property used by the UI to filter trials by country. Canonical values are controlled IRIs of skos:Concept in erct:CountryScheme, ideally aligned to ISO country identifiers. Legacy data may contain literal values. Pipelines should migrate or align literals to controlled concept IRIs via skos:altLabel or erct:legacyLiteralValue.</rdfs:comment>
    <erct:uiSection>Filters</erct:uiSection>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Trial"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#EntityWithProvenance">
    <rdfs:comment xml:lang="en">Any entity tracked with provenance metadata such as attribution, generation time, or generating activity.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Entity with provenance</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#isPublished">
    <rdfs:label xml:lang="en">is published</rdfs:label>
    <rdfs:comment xml:lang="en">Boolean flag indicating whether trial results are published.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#EntityWithProvenence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Entity with provenence (deprecated)</rdfs:label>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <rdfs:comment xml:lang="en">Deprecated misspelling. Use erct:EntityWithProvenance.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Ethics_Approval">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Ethics_Approval</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#stratifiedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://erct.adaptcentre.com/ontology#Stratified"/>
    <rdfs:range rdf:resource="https://erct.adaptcentre.com/ontology#demographicVariable"/>
    <rdfs:comment xml:lang="en">Specifies the demographic variable used in stratified randomisation, for example gender or county.</rdfs:comment>
    <rdfs:label xml:lang="en">stratified by</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#ManualIngestion">
    <rdfs:label xml:lang="en">Manual ingestion</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://erct.adaptcentre.com/ontology#IngestionMethod"/>
    <rdfs:comment xml:lang="en">Metadata entered manually without automated extraction support.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Analysis_Code_Format">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Analysis_Code_Format</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#EvidenceCompleteness_Partial">
    <skos:inScheme rdf:resource="https://erct.adaptcentre.com/ontology#EvidenceCompletenessScheme"/>
    <skos:prefLabel xml:lang="en">Partial</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#EvidenceTypeScheme">
    <rdfs:comment xml:lang="en">Controlled concept scheme describing the type of evidence source.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <rdfs:label xml:lang="en">Evidence type scheme</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://erct.adaptcentre.com/ontology#Language">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">Language</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
